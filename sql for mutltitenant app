CREATE OR REPLACE FUNCTION public.get_user_org()
RETURNS integer
LANGUAGE sql
STABLE
SECURITY DEFINER
SET search_path = pg_catalog, public
AS $$
  SELECT organization_id FROM public.profiles WHERE id = auth.uid();
$$;

